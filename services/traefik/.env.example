# Server IP — used to route the Traefik dashboard
# Dashboard will be at http://${SERVER_IP}:8080/dashboard/
SERVER_IP=YOUR_SERVER_IP

# Dashboard basic auth — format: "username:$$hashed_password"
# The $$ is required — Docker Compose needs it to escape $ in bcrypt hashes
#
# Generate your value by running this on the server:
#   echo $(htpasswd -nB yourpassword) | sed -e s/\\$/\\$\\$/g
#
# Then paste the full output (user:$$hash...) as the value below
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$examplehashreplaceme
