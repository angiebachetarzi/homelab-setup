# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=<timezone>

# User and group ID — makes sure files created by containers are owned by your user
# Run `id` on your server to get these values
PUID=1000
PGID=1000

# Path where all arr apps store their config
# Each app gets its own subfolder: config/radarr, config/sonarr, etc.
CONFIG_PATH=<config_path>

# Path to your media library root
# Update this if you change your drive — see REPATH.md
MEDIA_PATH=<media_path>

# Plex token — used by Overseerr to connect to your Plex server
# How to get it:
#   1. Log in to Plex web (app.plex.tv)
#   2. Open any media item → click the 3-dot menu → Get Info
#   3. At the bottom of the URL in your browser, find: X-Plex-Token=XXXXXXXX
#   4. Copy that token and paste it below
# Alternatively: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here
