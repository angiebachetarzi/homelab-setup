# Timezone
TZ=<timezone>

# Server IP — used to advertise Plex on the local network
SERVER_IP=<server_ip>

# Plex claim token — get one at https://plex.tv/claim (expires in 4 minutes)
# Only needed on first run to link the server to your Plex account
# You can remove or leave it empty after initial setup
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# Path where Plex stores its database, metadata and config
CONFIG_PATH=<config_path>

# Temporary transcoding cache — /tmp is fine, it's wiped on reboot
TRANSCODE_PATH=<transcode_path>

# Path to your media library
# Update this if you change your media drive — see REPATH.md
MEDIA_PATH=<media_path>
