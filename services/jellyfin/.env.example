# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=<timezone>

SERVER_IP=<server_ip>

# Path where all arr apps store their config
# Each app gets its own subfolder: config/radarr, config/sonarr, etc.
CONFIG_PATH=<config_path>

# Path to your media library root
# Update this if you change your drive — see REPATH.md
MEDIA_PATH=<media_path>
